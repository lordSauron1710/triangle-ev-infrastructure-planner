{
  "name": "triangle-ev-infrastructure-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc -b",
    "model:generate": "PYTHON=.venv/bin/python; [ -x \"$PYTHON\" ] || PYTHON=python3; \"$PYTHON\" model/optimize.py",
    "model:test": "PYTHON=.venv/bin/python; [ -x \"$PYTHON\" ] || PYTHON=python3; \"$PYTHON\" -m unittest discover -s model -p \"test_*.py\"",
    "model:check": "PYTHON=.venv/bin/python; [ -x \"$PYTHON\" ] || PYTHON=python3; \"$PYTHON\" model/optimize.py && git diff --exit-code src/versions/v1/data/generatedPlans.json",
    "verify": "npm run model:test && npm run model:check && npm run check && npm run build"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide-react": "^0.545.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
